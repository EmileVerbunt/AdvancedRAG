# --- Azure OpenAI / AI Foundry ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21

# Auth: "key" uses AZURE_OPENAI_API_KEY; "credential" uses DefaultAzureCredential.
AZURE_AUTH_MODE=key

# Recommended: a strong reasoning model (e.g. o3, o4-mini, gpt-4.1) for Discovery mode.
AZURE_OPENAI_REASONING_MODEL=o4-mini
# Recommended: a fast structured-output model (gpt-4.1-mini, gpt-4o-mini) for Governed extraction.
AZURE_OPENAI_EXTRACTION_MODEL=gpt-4.1-mini
# Recommended: a multimodal model (gpt-4o, gpt-4.1) for figure interpretation.
AZURE_OPENAI_VISION_MODEL=gpt-4.1
# Recommended: text-embedding-3-large (3072d) or text-embedding-3-small.
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# --- Azure Document Intelligence ---
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# --- Storage paths ---
GRAPH_STORAGE_PATH=./work/graph
VECTOR_DB_PATH=./work/qdrant
CHECKPOINT_PATH=./work/checkpoints
ARTIFACT_PATH=./work/artifacts
SQLITE_PATH=./work/knowledge_extraction.db

# --- Qdrant ---
# Leave QDRANT_URL empty to use embedded local storage at VECTOR_DB_PATH.
QDRANT_URL=
QDRANT_API_KEY=

# --- Telemetry ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_LOCAL_SINK_PATH=./work/telemetry/spans.jsonl
OTEL_SERVICE_NAME=knowledge_extraction

# --- Pipeline defaults ---
DEFAULT_MODE=governed             # discovery | governed
ACTIVE_ONTOLOGY_VERSION=          # blank => latest approved
LOG_LEVEL=INFO
